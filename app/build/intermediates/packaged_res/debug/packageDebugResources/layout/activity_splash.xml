<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_splash_gradient"
    android:padding="@dimen/padding_screen">

    <ImageView
        android:id="@+id/logoImage"
        android:layout_width="@dimen/splash_logo_size"
        android:layout_height="@dimen/splash_logo_size"
        android:contentDescription="@string/cd_app_logo"
        android:src="@drawable/ic_store_logo"
        app:layout_constraintBottom_toTopOf="@id/appName"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />

    <TextView
        android:id="@+id/appName"
        style="@style/TextAppearance.TiendaVirtual.DisplayMedium"
        android:layout_width="@dimen/spacing_none"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/margin_lg"
        android:gravity="center"
        android:text="@string/app_name"
        android:textColor="@color/color_on_primary"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/appTagline"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/logoImage" />

    <TextView
        android:id="@+id/appTagline"
        style="@style/TextAppearance.TiendaVirtual.BodyLarge"
        android:layout_width="@dimen/spacing_none"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/margin_sm"
        android:gravity="center"
        android:text="@string/app_tagline"
        android:textColor="@color/color_on_primary"
        app:layout_constraintBottom_toTopOf="@id/splashLoading"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/appName" />

    <TextView
        android:id="@+id/splashLoading"
        style="@style/TextAppearance.TiendaVirtual.BodyMedium"
        android:layout_width="@dimen/spacing_none"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/margin_xl"
        android:gravity="center"
        android:text="@string/splash_loading"
        android:textColor="@color/color_on_primary"
        app:layout_constraintBottom_toTopOf="@id/splashProgress"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/appTagline" />

    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:id="@+id/splashProgress"
        style="@style/Widget.TiendaVirtual.ProgressBar.Circular"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/margin_md"
        android:indeterminate="true"
        app:indicatorColor="@color/color_on_primary"
        app:indicatorSize="@dimen/progress_circular_size"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/splashLoading"
        app:trackColor="@color/color_ripple_on_dark" />

</androidx.constraintlayout.widget.ConstraintLayout>
