<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background"
    android:orientation="vertical"
    android:padding="@dimen/padding_screen">

    <TextView
        style="@style/TextAppearance.TiendaVirtual.HeadlineMedium"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/admin_product_management_hint" />

    <TextView
        android:id="@+id/adminProductsCount"
        style="@style/TextAppearance.TiendaVirtual.BodyMedium"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/margin_sm" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/adminProductsRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="@dimen/spacing_none"
        android:layout_marginTop="@dimen/margin_md"
        android:layout_weight="1" />

</LinearLayout>
