<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/padding_screen">

        <TextView
            android:id="@+id/sellerWelcome"
            style="@style/TextAppearance.TiendaVirtual.HeadlineLarge"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_lg"
            android:columnCount="2">

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.TiendaVirtual.Card.Stat"
                android:layout_width="@dimen/spacing_none"
                android:layout_height="@dimen/card_dashboard_stat_height"
                android:layout_columnWeight="1"
                android:layout_margin="@dimen/margin_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_card">

                    <TextView
                        android:id="@+id/totalRevenue"
                        style="@style/Widget.TiendaVirtual.StatCard.Value"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:adjustViewBounds="true"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textSize="@dimen/text_md" />

                    <TextView
                        style="@style/Widget.TiendaVirtual.StatCard.Label"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/seller_stat_total_revenue" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.TiendaVirtual.Card.Stat"
                android:layout_width="@dimen/spacing_none"
                android:layout_height="@dimen/card_dashboard_stat_height"
                android:layout_columnWeight="1"
                android:layout_margin="@dimen/margin_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_card">

                    <TextView
                        android:id="@+id/totalOrders"
                        style="@style/Widget.TiendaVirtual.StatCard.Value"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_lg" />

                    <TextView
                        style="@style/Widget.TiendaVirtual.StatCard.Label"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/seller_stat_total_orders" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.TiendaVirtual.Card.Stat"
                android:layout_width="@dimen/spacing_none"
                android:layout_height="@dimen/card_dashboard_stat_height"
                android:layout_columnWeight="1"
                android:layout_margin="@dimen/margin_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_card">

                    <TextView
                        android:id="@+id/activeProducts"
                        style="@style/Widget.TiendaVirtual.StatCard.Value"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_lg" />

                    <TextView
                        style="@style/Widget.TiendaVirtual.StatCard.Label"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/seller_stat_active_products" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.TiendaVirtual.Card.Stat"
                android:layout_width="@dimen/spacing_none"
                android:layout_height="@dimen/card_dashboard_stat_height"
                android:layout_columnWeight="1"
                android:layout_margin="@dimen/margin_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_card">

                    <TextView
                        android:id="@+id/lowStockProducts"
                        style="@style/Widget.TiendaVirtual.StatCard.Value"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_lg" />

                    <TextView
                        style="@style/Widget.TiendaVirtual.StatCard.Label"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/seller_stat_low_stock" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </GridLayout>

        <TextView
            style="@style/Widget.TiendaVirtual.SectionHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_lg"
            android:text="@string/seller_quick_actions_title" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/openProductsButton"
            style="@style/Widget.TiendaVirtual.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/nav_products" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/createProductButton"
            style="@style/Widget.TiendaVirtual.Button.Outlined"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_sm"
            android:text="@string/create_product_title" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/openOrdersButton"
            style="@style/Widget.TiendaVirtual.Button.Tonal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_sm"
            android:text="@string/nav_orders" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
