<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ================================================================== -->
    <!-- SHAPE APPEARANCES                                                   -->
    <!-- ================================================================== -->

    <style name="ShapeAppearance.TiendaVirtual.SmallComponent" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/radius_sm</item>
    </style>

    <style name="ShapeAppearance.TiendaVirtual.MediumComponent" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/radius_md</item>
    </style>

    <style name="ShapeAppearance.TiendaVirtual.LargeComponent" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/radius_lg</item>
    </style>

    <style name="ShapeAppearance.TiendaVirtual.Card" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/radius_card</item>
    </style>

    <style name="ShapeAppearance.TiendaVirtual.Button" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/radius_button</item>
    </style>

    <style name="ShapeAppearance.TiendaVirtual.Chip" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/radius_chip</item>
    </style>

    <style name="ShapeAppearance.TiendaVirtual.FAB" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/radius_lg</item>
    </style>

    <style name="ShapeAppearance.TiendaVirtual.BottomSheet" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">@dimen/radius_bottom_sheet</item>
        <item name="cornerSizeTopRight">@dimen/radius_bottom_sheet</item>
        <item name="cornerSizeBottomLeft">@dimen/radius_none</item>
        <item name="cornerSizeBottomRight">@dimen/radius_none</item>
    </style>

    <style name="ShapeAppearance.TiendaVirtual.Dialog" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/radius_dialog</item>
    </style>

    <style name="ShapeAppearance.TiendaVirtual.NavItem" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/radius_nav_item</item>
    </style>

    <!-- ================================================================== -->
    <!-- TEXT APPEARANCES — Material 3                                       -->
    <!-- ================================================================== -->

    <style name="TextAppearance.TiendaVirtual.DisplayLarge" parent="TextAppearance.Material3.DisplayLarge">
        <item name="android:textSize">@dimen/text_headline</item>
        <item name="android:textColor">@color/color_text_primary</item>
        <item name="android:fontFamily">sans-serif-light</item>
    </style>

    <style name="TextAppearance.TiendaVirtual.DisplayMedium" parent="TextAppearance.Material3.DisplayMedium">
        <item name="android:textSize">@dimen/text_display_xl</item>
        <item name="android:textColor">@color/color_text_primary</item>
    </style>

    <style name="TextAppearance.TiendaVirtual.DisplaySmall" parent="TextAppearance.Material3.DisplaySmall">
        <item name="android:textSize">@dimen/text_display_lg</item>
        <item name="android:textColor">@color/color_text_primary</item>
    </style>

    <style name="TextAppearance.TiendaVirtual.HeadlineLarge" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textSize">@dimen/text_display_md</item>
        <item name="android:textColor">@color/color_text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.TiendaVirtual.HeadlineMedium" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textSize">@dimen/text_display_sm</item>
        <item name="android:textColor">@color/color_text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.TiendaVirtual.HeadlineSmall" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:textSize">@dimen/text_xxl</item>
        <item name="android:textColor">@color/color_text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.TiendaVirtual.TitleLarge" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textSize">@dimen/text_xl</item>
        <item name="android:textColor">@color/color_text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.TiendaVirtual.TitleMedium" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">@dimen/text_lg</item>
        <item name="android:textColor">@color/color_text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.TiendaVirtual.TitleSmall" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:textSize">@dimen/text_md</item>
        <item name="android:textColor">@color/color_text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.TiendaVirtual.BodyLarge" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textSize">@dimen/text_lg</item>
        <item name="android:textColor">@color/color_text_primary</item>
    </style>

    <style name="TextAppearance.TiendaVirtual.BodyMedium" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">@dimen/text_md</item>
        <item name="android:textColor">@color/color_text_secondary</item>
    </style>

    <style name="TextAppearance.TiendaVirtual.BodySmall" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textSize">@dimen/text_sm</item>
        <item name="android:textColor">@color/color_text_tertiary</item>
    </style>

    <style name="TextAppearance.TiendaVirtual.LabelLarge" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textSize">@dimen/text_md</item>
        <item name="android:textColor">@color/color_text_secondary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.TiendaVirtual.LabelMedium" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textSize">@dimen/text_sm</item>
        <item name="android:textColor">@color/color_text_secondary</item>
    </style>

    <style name="TextAppearance.TiendaVirtual.LabelSmall" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textSize">@dimen/text_xs</item>
        <item name="android:textColor">@color/color_text_tertiary</item>
    </style>

    <!-- Variantes semánticas de precio -->
    <style name="TextAppearance.TiendaVirtual.Price" parent="TextAppearance.TiendaVirtual.TitleMedium">
        <item name="android:textColor">@color/color_price</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.TiendaVirtual.Price.Large" parent="TextAppearance.TiendaVirtual.HeadlineSmall">
        <item name="android:textColor">@color/color_price</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.TiendaVirtual.PriceOriginal" parent="TextAppearance.TiendaVirtual.BodySmall">
        <item name="android:textColor">@color/color_price_original</item>
        <item name="android:textStyle">normal</item>
    </style>

    <style name="TextAppearance.TiendaVirtual.Link" parent="TextAppearance.TiendaVirtual.BodyMedium">
        <item name="android:textColor">@color/color_text_link</item>
        <item name="android:textStyle">normal</item>
    </style>

    <!-- ================================================================== -->
    <!-- BOTONES                                                             -->
    <!-- ================================================================== -->

    <style name="Widget.TiendaVirtual.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:minHeight">@dimen/btn_height</item>
        <item name="cornerRadius">@dimen/radius_button</item>
        <item name="android:paddingStart">@dimen/padding_button_horizontal</item>
        <item name="android:paddingEnd">@dimen/padding_button_horizontal</item>
        <item name="backgroundTint">@color/color_primary</item>
        <item name="android:textColor">@color/color_on_primary</item>
        <item name="android:textSize">@dimen/btn_text_size</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="rippleColor">@color/color_ripple_on_dark</item>
    </style>

    <style name="Widget.TiendaVirtual.Button.Secondary" parent="Widget.Material3.Button">
        <item name="android:minHeight">@dimen/btn_height</item>
        <item name="cornerRadius">@dimen/radius_button</item>
        <item name="android:paddingStart">@dimen/padding_button_horizontal</item>
        <item name="android:paddingEnd">@dimen/padding_button_horizontal</item>
        <item name="backgroundTint">@color/color_secondary</item>
        <item name="android:textColor">@color/color_on_secondary</item>
        <item name="android:textSize">@dimen/btn_text_size</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="Widget.TiendaVirtual.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:minHeight">@dimen/btn_height</item>
        <item name="cornerRadius">@dimen/radius_button</item>
        <item name="android:paddingStart">@dimen/padding_button_horizontal</item>
        <item name="android:paddingEnd">@dimen/padding_button_horizontal</item>
        <item name="strokeColor">@color/color_primary</item>
        <item name="strokeWidth">@dimen/stroke_width</item>
        <item name="android:textColor">@color/color_primary</item>
        <item name="android:textSize">@dimen/btn_text_size</item>
    </style>

    <style name="Widget.TiendaVirtual.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:minHeight">@dimen/btn_height</item>
        <item name="android:textColor">@color/color_primary</item>
        <item name="android:textSize">@dimen/btn_text_size</item>
        <item name="rippleColor">@color/color_ripple_primary</item>
    </style>

    <style name="Widget.TiendaVirtual.Button.Danger" parent="Widget.Material3.Button">
        <item name="android:minHeight">@dimen/btn_height</item>
        <item name="cornerRadius">@dimen/radius_button</item>
        <item name="backgroundTint">@color/color_error</item>
        <item name="android:textColor">@color/color_on_error</item>
        <item name="android:textSize">@dimen/btn_text_size</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="Widget.TiendaVirtual.Button.Small" parent="Widget.Material3.Button">
        <item name="android:minHeight">@dimen/btn_height_small</item>
        <item name="cornerRadius">@dimen/radius_sm</item>
        <item name="android:paddingStart">@dimen/spacing_md</item>
        <item name="android:paddingEnd">@dimen/spacing_md</item>
        <item name="android:textSize">@dimen/text_sm</item>
    </style>

    <style name="Widget.TiendaVirtual.Button.Tonal" parent="Widget.Material3.Button.TonalButton">
        <item name="android:minHeight">@dimen/btn_height</item>
        <item name="cornerRadius">@dimen/radius_button</item>
        <item name="backgroundTint">@color/color_primary_container</item>
        <item name="android:textColor">@color/color_on_primary_container</item>
        <item name="android:textSize">@dimen/btn_text_size</item>
    </style>

    <!-- ================================================================== -->
    <!-- TARJETAS — MaterialCardView                                         -->
    <!-- ================================================================== -->

    <style name="Widget.TiendaVirtual.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">@dimen/radius_card</item>
        <item name="cardElevation">@dimen/elevation_card</item>
        <item name="cardBackgroundColor">@color/color_surface</item>
        <item name="contentPadding">@dimen/padding_card</item>
        <item name="rippleColor">@color/color_ripple_primary</item>
        <item name="strokeColor">@color/transparent</item>
    </style>

    <style name="Widget.TiendaVirtual.Card.Outlined" parent="Widget.Material3.CardView.Outlined">
        <item name="cardCornerRadius">@dimen/radius_card</item>
        <item name="cardElevation">@dimen/elevation_none</item>
        <item name="cardBackgroundColor">@color/color_surface</item>
        <item name="strokeColor">@color/color_outline</item>
        <item name="strokeWidth">@dimen/stroke_width</item>
        <item name="contentPadding">@dimen/padding_card</item>
    </style>

    <style name="Widget.TiendaVirtual.Card.Flat" parent="Widget.Material3.CardView.Filled">
        <item name="cardCornerRadius">@dimen/radius_card</item>
        <item name="cardElevation">@dimen/elevation_none</item>
        <item name="cardBackgroundColor">@color/color_surface_variant</item>
        <item name="contentPadding">@dimen/padding_card</item>
    </style>

    <style name="Widget.TiendaVirtual.Card.Product" parent="Widget.TiendaVirtual.Card">
        <item name="contentPadding">@dimen/spacing_none</item>
        <item name="cardCornerRadius">@dimen/radius_card_large</item>
        <item name="cardElevation">@dimen/elevation_sm</item>
    </style>

    <style name="Widget.TiendaVirtual.Card.Stat" parent="Widget.TiendaVirtual.Card.Flat">
        <item name="cardCornerRadius">@dimen/radius_lg</item>
        <item name="contentPadding">@dimen/padding_card</item>
    </style>

    <!-- ================================================================== -->
    <!-- CAMPOS DE TEXTO — TextInputLayout                                   -->
    <!-- ================================================================== -->

    <style name="Widget.TiendaVirtual.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">@dimen/radius_input</item>
        <item name="boxCornerRadiusTopEnd">@dimen/radius_input</item>
        <item name="boxCornerRadiusBottomStart">@dimen/radius_input</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/radius_input</item>
        <item name="boxStrokeColor">@color/color_outline</item>
        <item name="boxStrokeWidth">@dimen/stroke_width</item>
        <item name="boxStrokeWidthFocused">@dimen/stroke_width_medium</item>
        <item name="hintTextColor">@color/color_primary</item>
        <item name="android:minHeight">@dimen/input_height</item>
    </style>

    <style name="Widget.TiendaVirtual.TextInputLayout.Filled" parent="Widget.Material3.TextInputLayout.FilledBox">
        <item name="boxCornerRadiusTopStart">@dimen/radius_input</item>
        <item name="boxCornerRadiusTopEnd">@dimen/radius_input</item>
        <item name="boxCornerRadiusBottomStart">@dimen/radius_none</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/radius_none</item>
        <item name="boxBackgroundColor">@color/color_surface_variant</item>
        <item name="hintTextColor">@color/color_primary</item>
        <item name="android:minHeight">@dimen/input_height</item>
    </style>

    <style name="Widget.TiendaVirtual.TextInputLayout.Search" parent="Widget.Material3.TextInputLayout.FilledBox">
        <item name="boxCornerRadiusTopStart">@dimen/radius_full</item>
        <item name="boxCornerRadiusTopEnd">@dimen/radius_full</item>
        <item name="boxCornerRadiusBottomStart">@dimen/radius_full</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/radius_full</item>
        <item name="boxBackgroundColor">@color/color_surface_variant</item>
        <item name="boxStrokeWidth">@dimen/stroke_none</item>
        <item name="boxStrokeWidthFocused">@dimen/stroke_none</item>
        <item name="hintTextColor">@color/color_text_tertiary</item>
    </style>

    <!-- ================================================================== -->
    <!-- CHIPS                                                               -->
    <!-- ================================================================== -->

    <style name="Widget.TiendaVirtual.Chip.Filter" parent="Widget.Material3.Chip.Filter">
        <item name="chipCornerRadius">@dimen/radius_chip</item>
        <item name="chipMinHeight">@dimen/chip_height</item>
        <item name="android:textSize">@dimen/text_sm</item>
        <item name="chipStrokeColor">@color/color_outline</item>
        <item name="chipStrokeWidth">@dimen/stroke_width</item>
        <item name="checkedIconVisible">true</item>
        <item name="chipBackgroundColor">@color/color_surface</item>
        <item name="android:textColor">@color/color_text_secondary</item>
    </style>

    <style name="Widget.TiendaVirtual.Chip.Suggestion" parent="Widget.Material3.Chip.Suggestion">
        <item name="chipCornerRadius">@dimen/radius_chip</item>
        <item name="chipMinHeight">@dimen/chip_height</item>
        <item name="android:textSize">@dimen/text_sm</item>
        <item name="chipBackgroundColor">@color/color_primary_container</item>
        <item name="android:textColor">@color/color_on_primary_container</item>
        <item name="chipStrokeWidth">@dimen/stroke_none</item>
    </style>

    <style name="Widget.TiendaVirtual.Chip.Status" parent="Widget.Material3.Chip.Assist">
        <item name="chipCornerRadius">@dimen/radius_chip</item>
        <item name="chipMinHeight">@dimen/chip_height</item>
        <item name="chipStrokeWidth">@dimen/stroke_none</item>
        <item name="android:textSize">@dimen/text_xs</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="chipIconSize">@dimen/chip_icon_size</item>
    </style>

    <!-- ================================================================== -->
    <!-- TOP APP BAR                                                         -->
    <!-- ================================================================== -->

    <style name="Widget.TiendaVirtual.TopAppBar" parent="Widget.Material3.Toolbar.Surface">
        <item name="android:background">@color/color_top_app_bar_background</item>
        <item name="titleTextColor">@color/color_text_primary</item>
        <item name="subtitleTextColor">@color/color_text_secondary</item>
        <item name="elevation">@dimen/elevation_app_bar</item>
        <item name="contentInsetStartWithNavigation">0dp</item>
        <item name="titleTextAppearance">@style/TextAppearance.TiendaVirtual.TitleLarge</item>
    </style>

    <style name="Widget.TiendaVirtual.TopAppBar.Primary" parent="Widget.Material3.Toolbar">
        <item name="android:background">@color/color_primary</item>
        <item name="titleTextColor">@color/color_on_primary</item>
        <item name="subtitleTextColor">@color/color_primary_light</item>
        <item name="elevation">@dimen/elevation_app_bar</item>
    </style>

    <!-- ================================================================== -->
    <!-- BOTTOM NAVIGATION                                                   -->
    <!-- ================================================================== -->

    <style name="Widget.TiendaVirtual.BottomNavigation" parent="Widget.Material3.BottomNavigationView">
        <item name="android:background">@color/color_bottom_nav_background</item>
        <item name="labelVisibilityMode">labeled</item>
        <item name="elevation">@dimen/elevation_bottom_nav</item>
        <item name="itemRippleColor">@color/color_ripple_primary</item>
        <item name="itemIconTint">@null</item>
        <item name="itemTextColor">@null</item>
    </style>

    <!-- ================================================================== -->
    <!-- FLOATING ACTION BUTTON                                              -->
    <!-- ================================================================== -->

    <style name="Widget.TiendaVirtual.FAB" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="backgroundTint">@color/color_primary</item>
        <item name="tint">@color/color_on_primary</item>
        <item name="elevation">@dimen/elevation_fab</item>
        <item name="shapeAppearance">@style/ShapeAppearance.TiendaVirtual.FAB</item>
        <item name="rippleColor">@color/color_ripple_on_dark</item>
    </style>

    <style name="Widget.TiendaVirtual.FAB.Extended" parent="Widget.Material3.ExtendedFloatingActionButton.Primary">
        <item name="backgroundTint">@color/color_primary</item>
        <item name="android:textColor">@color/color_on_primary</item>
        <item name="iconTint">@color/color_on_primary</item>
        <item name="elevation">@dimen/elevation_fab</item>
    </style>

    <!-- ================================================================== -->
    <!-- NAVIGATION DRAWER                                                   -->
    <!-- ================================================================== -->

    <style name="Widget.TiendaVirtual.NavigationView" parent="Widget.Material3.NavigationView">
        <item name="android:background">@color/color_surface</item>
        <item name="itemTextColor">@color/color_text_primary</item>
        <item name="itemIconTint">@color/color_primary</item>
        <item name="itemShapeAppearance">@style/ShapeAppearance.TiendaVirtual.NavItem</item>
        <item name="itemShapeFillColor">@color/color_primary_container</item>
    </style>

    <!-- ================================================================== -->
    <!-- DIÁLOGOS                                                            -->
    <!-- ================================================================== -->

    <style name="Widget.TiendaVirtual.Dialog" parent="ThemeOverlay.TiendaVirtual.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
    </style>

    <!-- ================================================================== -->
    <!-- BOTTOM SHEET                                                        -->
    <!-- ================================================================== -->

    <style name="Widget.TiendaVirtual.BottomSheet" parent="Widget.Material3.BottomSheet">
        <item name="android:background">@color/color_surface</item>
        <item name="shapeAppearance">@style/ShapeAppearance.TiendaVirtual.BottomSheet</item>
        <item name="backgroundTint">@color/color_surface</item>
    </style>

    <!-- ================================================================== -->
    <!-- DIVISORES                                                           -->
    <!-- ================================================================== -->

    <style name="Widget.TiendaVirtual.Divider" parent="Widget.Material3.MaterialDivider">
        <item name="dividerColor">@color/color_outline_variant</item>
        <item name="dividerThickness">@dimen/divider_height</item>
        <item name="dividerInsetStart">@dimen/divider_indent</item>
        <item name="dividerInsetEnd">@dimen/divider_indent</item>
    </style>

    <!-- ================================================================== -->
    <!-- PROGRESS INDICATORS                                                 -->
    <!-- ================================================================== -->

    <style name="Widget.TiendaVirtual.ProgressBar.Linear" parent="Widget.Material3.LinearProgressIndicator">
        <item name="indicatorColor">@color/color_primary</item>
        <item name="trackColor">@color/color_primary_container</item>
        <item name="trackThickness">@dimen/progress_bar_height</item>
        <item name="trackCornerRadius">@dimen/radius_full</item>
    </style>

    <style name="Widget.TiendaVirtual.ProgressBar.Circular" parent="Widget.Material3.CircularProgressIndicator">
        <item name="indicatorColor">@color/color_primary</item>
        <item name="trackColor">@color/color_primary_container</item>
    </style>

    <!-- ================================================================== -->
    <!-- SWITCH / CHECKBOX / RADIO BUTTON                                    -->
    <!-- ================================================================== -->

    <style name="Widget.TiendaVirtual.Switch" parent="Widget.Material3.CompoundButton.Switch">
        <item name="thumbTint">@color/color_on_primary</item>
        <item name="trackTint">@color/color_primary</item>
    </style>

    <style name="Widget.TiendaVirtual.Checkbox" parent="Widget.Material3.CompoundButton.CheckBox">
        <item name="buttonTint">@color/color_primary</item>
    </style>

    <style name="Widget.TiendaVirtual.RadioButton" parent="Widget.Material3.CompoundButton.RadioButton">
        <item name="buttonTint">@color/color_primary</item>
    </style>

    <!-- ================================================================== -->
    <!-- SLIDER                                                              -->
    <!-- ================================================================== -->

    <style name="Widget.TiendaVirtual.Slider" parent="Widget.Material3.Slider">
        <item name="thumbColor">@color/color_primary</item>
        <item name="trackColorActive">@color/color_primary</item>
        <item name="trackColorInactive">@color/color_primary_container</item>
        <item name="haloColor">@color/color_ripple_primary</item>
    </style>

    <!-- ================================================================== -->
    <!-- SNACKBAR                                                            -->
    <!-- ================================================================== -->

    <style name="Widget.TiendaVirtual.Snackbar" parent="Widget.Material3.Snackbar">
        <item name="android:layout_margin">@dimen/snackbar_margin</item>
        <item name="backgroundTint">@color/color_on_surface</item>
        <item name="actionTextColorAlpha">1</item>
    </style>

    <!-- ================================================================== -->
    <!-- ESTADO VACÍO (empty state)                                          -->
    <!-- ================================================================== -->

    <style name="Widget.TiendaVirtual.EmptyState.Title" parent="TextAppearance.TiendaVirtual.HeadlineSmall">
        <item name="android:textColor">@color/color_text_secondary</item>
        <item name="android:gravity">center</item>
        <item name="android:textAlignment">center</item>
    </style>

    <style name="Widget.TiendaVirtual.EmptyState.Subtitle" parent="TextAppearance.TiendaVirtual.BodyMedium">
        <item name="android:textColor">@color/color_text_tertiary</item>
        <item name="android:gravity">center</item>
        <item name="android:textAlignment">center</item>
    </style>

    <!-- ================================================================== -->
    <!-- ENCABEZADO DE SECCIÓN                                               -->
    <!-- ================================================================== -->

    <style name="Widget.TiendaVirtual.SectionHeader" parent="TextAppearance.TiendaVirtual.TitleMedium">
        <item name="android:textColor">@color/color_text_primary</item>
        <item name="android:paddingTop">@dimen/spacing_sm</item>
        <item name="android:paddingBottom">@dimen/spacing_sm</item>
    </style>

    <!-- ================================================================== -->
    <!-- BADGE DE DESCUENTO                                                  -->
    <!-- ================================================================== -->

    <style name="Widget.TiendaVirtual.DiscountBadge" parent="TextAppearance.TiendaVirtual.LabelSmall">
        <item name="android:textColor">@color/color_discount_badge_text</item>
        <item name="android:background">@color/color_discount_badge</item>
        <item name="android:paddingStart">@dimen/badge_padding_horizontal</item>
