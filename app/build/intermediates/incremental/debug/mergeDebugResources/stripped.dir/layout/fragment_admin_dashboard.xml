<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/padding_screen">

        <TextView
            style="@style/TextAppearance.TiendaVirtual.HeadlineLarge"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/admin_dashboard_welcome" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_lg"
            android:columnCount="2">

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.TiendaVirtual.Card.Stat"
                android:layout_width="@dimen/spacing_none"
                android:layout_height="@dimen/card_dashboard_stat_height"
                android:layout_columnWeight="1"
                android:layout_margin="@dimen/margin_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_card">

                    <TextView
                        android:id="@+id/totalUsers"
                        style="@style/Widget.TiendaVirtual.StatCard.Value"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_lg" />

                    <TextView
                        style="@style/Widget.TiendaVirtual.StatCard.Label"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="2"
                        android:text="@string/admin_stat_total_users" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.TiendaVirtual.Card.Stat"
                android:layout_width="@dimen/spacing_none"
                android:layout_height="@dimen/card_dashboard_stat_height"
                android:layout_columnWeight="1"
                android:layout_margin="@dimen/margin_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_card">

                    <TextView
                        android:id="@+id/totalProducts"
                        style="@style/Widget.TiendaVirtual.StatCard.Value"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_lg" />

                    <TextView
                        style="@style/Widget.TiendaVirtual.StatCard.Label"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="2"
                        android:text="@string/admin_stat_total_products" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.TiendaVirtual.Card.Stat"
                android:layout_width="@dimen/spacing_none"
                android:layout_height="@dimen/card_dashboard_stat_height"
                android:layout_columnWeight="1"
                android:layout_margin="@dimen/margin_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_card">

                    <TextView
                        android:id="@+id/totalOrders"
                        style="@style/Widget.TiendaVirtual.StatCard.Value"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_lg" />

                    <TextView
                        style="@style/Widget.TiendaVirtual.StatCard.Label"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="2"
                        android:text="@string/admin_stat_total_orders" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.TiendaVirtual.Card.Stat"
                android:layout_width="@dimen/spacing_none"
                android:layout_height="@dimen/card_dashboard_stat_height"
                android:layout_columnWeight="1"
                android:layout_margin="@dimen/margin_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_card">

                    <TextView
                        android:id="@+id/monthlyRevenue"
                        style="@style/Widget.TiendaVirtual.StatCard.Value"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:adjustViewBounds="true"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textSize="@dimen/text_md" />

                    <TextView
                        style="@style/Widget.TiendaVirtual.StatCard.Label"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="2"
                        android:text="@string/admin_stat_monthly_revenue" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </GridLayout>

        <TextView
            style="@style/Widget.TiendaVirtual.SectionHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_lg"
            android:text="@string/admin_chart_users_by_role" />

        <TextView
            android:id="@+id/adminUsersBarLabel"
            style="@style/TextAppearance.TiendaVirtual.BodyMedium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/adminUsersBar"
            style="@style/Widget.TiendaVirtual.ProgressBar.Linear"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_sm"
            android:max="100" />

        <TextView
            style="@style/Widget.TiendaVirtual.SectionHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_lg"
            android:text="@string/admin_section_recent_activity" />

        <TextView
            style="@style/TextAppearance.TiendaVirtual.BodyMedium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/admin_recent_activity_mock" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
