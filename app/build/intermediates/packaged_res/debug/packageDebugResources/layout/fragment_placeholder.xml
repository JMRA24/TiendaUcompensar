<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background"
    android:padding="@dimen/padding_screen">

    <ImageView
        android:id="@+id/placeholderIcon"
        android:layout_width="@dimen/icon_empty_state"
        android:layout_height="@dimen/icon_empty_state"
        android:contentDescription="@string/cd_app_logo"
        android:src="@drawable/ic_store_logo"
        app:layout_constraintBottom_toTopOf="@id/placeholderTitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />

    <TextView
        android:id="@+id/placeholderTitle"
        style="@style/TextAppearance.TiendaVirtual.HeadlineMedium"
        android:layout_width="@dimen/spacing_none"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/margin_lg"
        android:gravity="center"
        app:layout_constraintBottom_toTopOf="@id/placeholderSubtitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/placeholderIcon" />

    <TextView
        android:id="@+id/placeholderSubtitle"
        style="@style/TextAppearance.TiendaVirtual.BodyMedium"
        android:layout_width="@dimen/spacing_none"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/margin_sm"
        android:gravity="center"
        android:text="@string/navigation_placeholder_subtitle"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/placeholderTitle" />

</androidx.constraintlayout.widget.ConstraintLayout>
