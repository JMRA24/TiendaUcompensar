<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/padding_screen">

        <ImageView
            android:id="@+id/productDetailImage"
            android:layout_width="match_parent"
            android:layout_height="@dimen/product_image_detail_height"
            android:background="@drawable/bg_rounded_card"
            android:contentDescription="@string/cd_product_image_generic"
            android:padding="@dimen/spacing_xl"
            android:src="@drawable/ic_placeholder_product" />

        <TextView
            android:id="@+id/productDetailName"
            style="@style/TextAppearance.TiendaVirtual.HeadlineLarge"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_lg" />

        <TextView
            android:id="@+id/productDetailPrice"
            style="@style/TextAppearance.TiendaVirtual.Price.Large"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_sm" />

        <TextView
            android:id="@+id/productDetailRating"
            style="@style/TextAppearance.TiendaVirtual.BodyMedium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_sm" />

        <TextView
            style="@style/Widget.TiendaVirtual.SectionHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_lg"
            android:text="@string/product_label_description" />

        <TextView
            android:id="@+id/productDetailDescription"
            style="@style/TextAppearance.TiendaVirtual.BodyLarge"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/productDetailStock"
            style="@style/TextAppearance.TiendaVirtual.BodyMedium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_lg" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/addToCartButton"
            style="@style/Widget.TiendaVirtual.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_lg"
            android:text="@string/btn_add_to_cart" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
